# NeonDB PostgreSQL connection string
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5 secret - generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"

# Base URL of the application
AUTH_URL="http://localhost:3000"

# OPENAI API Key
OPENAI_API_KEY="your-openai-api-key-here"

# ElevenLabs post-call webhook HMAC secret (from ElevenAgents webhook settings)
ELEVENLABS_WH_SECRET="your-elevenlabs-wh-secret-here"

# Optional: used by the SDK client constructor; webhook verification only needs ELEVENLABS_WH_SECRET
# ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# Snowflake Cortex — used for SENTIMENT() analysis on user transcript lines
SNOWFLAKE_ACCOUNT="your-account-identifier"
SNOWFLAKE_USERNAME="your-username"
SNOWFLAKE_PASSWORD="your-password"
SNOWFLAKE_DATABASE="your-database"
SNOWFLAKE_SCHEMA="PUBLIC"
SNOWFLAKE_WAREHOUSE="your-warehouse"

# If account requires MFA, use key-pair auth instead of password (omit SNOWFLAKE_PASSWORD):
# Generate keys: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
# Register public key in Snowflake: ALTER USER <username> SET RSA_PUBLIC_KEY='<contents of rsa_key.pub>';
SNOWFLAKE_PRIVATE_KEY_PATH="rsa_key.p8"