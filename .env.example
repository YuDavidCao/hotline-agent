# NeonDB PostgreSQL connection string
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5 secret - generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"

# Base URL of the application
AUTH_URL="http://localhost:3000"

# OPENAI API Key
OPENAI_API_KEY="your-openai-api-key-here"

# ElevenLabs post-call webhook HMAC secret (from ElevenAgents webhook settings)
ELEVENLABS_WH_SECRET="your-elevenlabs-wh-secret-here"

